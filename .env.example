# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexus:CHANGE_ME@localhost:5432/nexus
DB_PASSWORD=CHANGE_ME

# ── Session security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME

# ── Telegram alerts ───────────────────────────────────────────────────────────
# PENDING: Create a dedicated Nexus bot via @BotFather
NEXUS_TELEGRAM_BOT_TOKEN=PENDING
# Benjamin's Telegram chat ID (used for OTP login and alerts)
NEXUS_TELEGRAM_ADMIN_CHAT_ID=8711488487

# ── Billing APIs (populate when keys are available) ───────────────────────────
# PENDING: Anthropic Console billing API key (from console.anthropic.com)
ANTHROPIC_BILLING_KEY=PENDING
# PENDING: xAI Console billing API key
XAI_BILLING_KEY=PENDING

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Once Grafana is deployed, set this to embed it in the Infrastructure tab:
VITE_GRAFANA_URL=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Heartbeat thresholds (optional) ──────────────────────────────────────────
HEARTBEAT_INTERVAL_SECS=300
HEARTBEAT_MISSED_ALERT_COUNT=3
